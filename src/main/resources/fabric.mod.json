{
  "schemaVersion": 1,
  "id": "pet_recall",
  "version": "${version}",
  "name": "NoLostPets",
  "description": "Recall pets from unloaded chunks without loading chunks (no chunk loading), with safe vanilla-style teleport spots and loaded-pet support.",
  "authors": [
    "Zlo"
  ],
  "contact": {},
  "license": "GPL-3.0-only",
  "icon": "assets/pet_recall/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.creas.petrecall.PetRecallMod"
    ]
  },
  "mixins": [
    "pet-recall.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version_range}",
    "java": ">=21"
  }
}
